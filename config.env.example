# Lades-Pro-MD Configuration
# Copy this file to config.env and fill in your values.

# ── Bot Identity ────────────────────────────────────────
BOT_NAME=Lades-Pro-MD
OWNER_NUMBER=905396978235         # Bot owner phone number (no +)
PREFIX=.                          # Command prefix

# ── WhatsApp Session ────────────────────────────────────
SESSION=                          # Base64 session string (run: node scripts/pair.js)
# PAIR_PHONE=905XXXXXXXXX         # Set to auto-use pair code on startup

# ── Database ─────────────────────────────────────────────────────────────────
# Desteklenen platformlar / Supported platforms:
#
#  1) SQLite (varsayılan / default) — Geliştirme veya küçük botlar için
#     DATABASE_URL=                    (boş bırak / leave empty)
#
#  2) Neon PostgreSQL (ÜCRETSİZ tier mevcut / FREE tier available)
#     https://neon.tech → Proje oluştur → Connection string kopyala
#     DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
#
#  3) Supabase PostgreSQL (ÜCRETSİZ tier mevcut / FREE tier available)
#     https://supabase.com → Project → Settings → Database → Connection string
#     DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
#
#  4) Render Database (Render.com üzerinde PostgreSQL)
#     https://dashboard.render.com → New → PostgreSQL → Internal DB URL
#     DATABASE_URL=postgresql://user:pass@dpg-xxx.oregon-postgres.render.com/dbname
#
#  5) MongoDB ⚠️ UYARI: Desteklenmiyor
#     Sequelize ORM MongoDB ile çalışmaz. Neon/Supabase (ücretsiz) kullanın.
#     DATABASE_URL=mongodb+srv://...  → Bot SQLite'a otomatik geri döner + uyarı verir
#
DATABASE_URL=                     # Yukarıdan birini seçin veya boş bırakın (SQLite)
DB_SSL=true                       # PostgreSQL için SSL (Neon/Supabase zorunlu, yerel için false)
DB_POOL_MAX=10
DB_POOL_MIN=2

# ── AI Features ─────────────────────────────────────────
GEMINI_API_KEY=                   # Google AI Studio API key
OPENAI_API_KEY=                   # OpenAI API key (optional, fallback)
AI_MODEL=gemini                   # gemini or openai

# ── Permissions ──────────────────────────────────────────
SUDO=                             # Comma-separated sudo user numbers: 905XXX,905YYY
PUBLIC_MODE=true                  # true = responds to everyone, false = owner/sudo only
MODE=public                       # public or private
ADMIN_ACCESS=true                 # true = grup yöneticileri admin komutlarını kullanabilir

# ── WhatsApp Channel (Newsletter) Support ────────────────
# Bot artık @newsletter (WhatsApp Kanalları) ile %100 uyumludur.
# Kanal üzerinden komut göndermek için:
#   1. Botu kanalınızın yöneticisi olarak ekleyin
#   2. Kanal içinden .komut yazın → Bot cevap verir
# Komutlar (örnekler): .jid .ping .alive .yardım vb.

# ── Features ────────────────────────────────────────────
AUTO_READ=false                   # Auto read messages
AUTO_TYPING=true                  # Show typing indicator
AUTO_RECORDING=false              # Show recording indicator
ANTI_LINK=false                   # Global anti-link (per-group setting overrides)
ANTI_SPAM=false                   # Basic spam protection
REJECT_CALLS=false                # Reject incoming calls
SEND_REACTIONS=true               # Show ⏳/✅/❌ reactions on command execution

# ── Performance ──────────────────────────────────────────
HEAP_LIMIT_MB=512                 # GC warning threshold (MB)
PM2_RESTART_LIMIT_MB=450          # PM2 restart threshold (MB)
LOG_LEVEL=info                    # pino log level: debug, info, warn, error
NODE_ENV=production
DEBUG=false                       # true = verbose debug logs (komut akışını izlemek için)

# ── Server ───────────────────────────────────────────────
PORT=3000                         # HTTP keepalive server port

# ── Session ──────────────────────────────────────────────
PAIR_AUTO_LOGOUT=false            # Keep session logged in after pair.js

# ── Localization ─────────────────────────────────────────
LANG=turkish
BOT_INFO=Lades-Pro;Lades Yönetimi;
STICKER_DATA=Lades-Pro;Lades-Pro;😂
ALIVE=
SELF_TEST=false                   # true = startup'ta tüm komutları test et
