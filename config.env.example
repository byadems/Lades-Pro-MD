# Lades-Pro Configuration
# Northflank deployment'i için bu dosyayı config.env'e kopyalayıp doldurun
# (Northflank'te "Environment" sekmesinden de set edebilirsiniz).

# ── Bot Identity ────────────────────────────────────────
BOT_NAME=Lades-Pro
OWNER_NUMBER=905396978235         # Bot owner phone number (no +)
PREFIX=.                          # Command prefix

# ── WhatsApp Session ────────────────────────────────────
SESSION=                          # Base64 session string (run: node scripts/pair.js)
# PAIR_PHONE=905XXXXXXXXX         # Set to auto-use pair code on startup

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Northflank standardı: DATABASE_URL. Replit eski deployment'larıyla uyumlu
# kalmak için EXTERNAL_DB_URL ve PG_URL de kabul edilir; öncelik DATABASE_URL.
#
# Northflank dahili PostgreSQL addon kullanıyorsanız Northflank otomatik olarak
# DATABASE_URL'i set eder; bu satırı boş bırakabilirsiniz.
#
# Harici sağlayıcı örnekleri:
#  • Neon       — postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
#  • Supabase   — postgresql://postgres:[pwd]@db.[ref].supabase.co:5432/postgres
#  • Render     — postgresql://user:pass@dpg-xxx.oregon-postgres.render.com/dbname
#
# DATABASE_URL boşsa bot yerel SQLite'a düşer (sadece geliştirme için).
DATABASE_URL=
DB_SSL=auto                       # auto = URL'e göre algıla; true/false ile zorla
DB_POOL_MAX=3                     # 0.2 vCPU / 512MB için ideal (artırırsanız RAM'e dikkat)
DB_POOL_MIN=1

# ── AI Features ─────────────────────────────────────────
GEMINI_API_KEY=                   # Google AI Studio API key
OPENAI_API_KEY=                   # OpenAI API key (optional, fallback)
AI_MODEL=gemini                   # gemini or openai

# ── Permissions ──────────────────────────────────────────
SUDO=                             # Comma-separated sudo user numbers: 905XXX,905YYY
PUBLIC_MODE=true                  # true = responds to everyone, false = owner/sudo only
MODE=public                       # public or private
ADMIN_ACCESS=true                 # true = grup yöneticileri admin komutlarını kullanabilir

# ── WhatsApp Channel (Newsletter) Support ────────────────
# Bot artık @newsletter (WhatsApp Kanalları) ile %100 uyumludur.
# Kanal üzerinden komut göndermek için:
#   1. Botu kanalınızın yöneticisi olarak ekleyin
#   2. Kanal içinden .komut yazın → Bot cevap verir

# ── Features ────────────────────────────────────────────
AUTO_READ=false                   # Auto read messages
AUTO_TYPING=true                  # Show typing indicator
AUTO_RECORDING=false              # Show recording indicator
ANTI_LINK=false                   # Global anti-link (per-group setting overrides)
ANTI_SPAM=false                   # Basic spam protection
REJECT_CALLS=false                # Reject incoming calls
SEND_REACTIONS=true               # Show ⏳/✅/❌ reactions on command execution

# ── Performance (0.2 vCPU / 512 MB / 2 GB hedefi) ────────────────────
PM2_RESTART_LIMIT_MB=380          # RSS bu değeri aşarsa temiz restart (OOM-kill öncesi)
PQUEUE_CONCURRENCY=6              # Eşzamanlı mesaj işleme (0.2 vCPU için 6 ideal)
PQUEUE_INTERVAL_CAP=15            # Saniyedeki max işlem sayısı
SCHEDULER_TICK_MS=20000           # Periyodik görev tick'i (ms)
DISK_BUDGET_BYTES=2147483648      # 2 GB disk bütçesi (Northflank quota'ya göre ayarla)
LOG_LEVEL=info                    # pino: debug, info, warn, error
NODE_ENV=production
DEBUG=false                       # true = verbose debug

# ── Server ───────────────────────────────────────────────
PORT=3000                         # HTTP keepalive / healthcheck portu
DASHBOARD_PORT=3001               # Web dashboard portu

# ── Session ──────────────────────────────────────────────
PAIR_AUTO_LOGOUT=false            # Keep session logged in after pair.js

# ── Localization ─────────────────────────────────────────
LANG=turkish
BOT_INFO=Lades-Pro;Lades Yönetimi;
STICKER_DATA=Lades-Pro;Lades-Pro;😂
ALIVE=
SELF_TEST=false                   # true = startup'ta tüm komutları test et
